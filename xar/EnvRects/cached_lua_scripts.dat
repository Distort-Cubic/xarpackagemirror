BEGIN_FILE: "../../Data/Packages/xar/EnvRects/env_rect_arcade_enter.lua"
function p.__on_touch()
    game_arcade.set_inside_arcade()
end
END_FILE
BEGIN_FILE: "../../Data/Packages/xar/EnvRects/env_rect_arcade_exit.lua"
function p.__on_touch()
    game_arcade.set_outside_arcade()
end
END_FILE
BEGIN_FILE: "../../Data/Packages/xar/EnvRects/env_rect_death_key_laser_genesis.lua"
function p.__on_touch()
    if( ga_get_f("xar.key_time.laser_genesis") > 0 ) then
        --The player has the key.
        return
    end
    --The player does not have the key.
    ga_kill_player()
end
END_FILE

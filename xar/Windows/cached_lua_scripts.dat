            end
            ga_set_i("xar.player.gun6.ammo", ammo)
        end
        p.make_list(wid)
        ga_win_widget_small_list_set_selected(wid, 4) --Fragile!!!
    end
    if sel_str == "7" and game_can_use.main(7) then
        local price = 5
        for i = 1,20 do

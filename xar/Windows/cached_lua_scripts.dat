    ga_win_txt(wid, 0.2, 0.64, " DAMAGE PER SEC:")
    ga_win_txt(wid, 0.2, 0.60, "DAMAGE PER AMMO:")
    ga_win_txt(wid, 0.2, 0.56, "    FREEZE TIME:")

    local var = "movement.black_hole_drive.alt_radius"
    ga_package_init_i(var, 3)
    return ga_package_get_i(var)
end

function p.set_alt_radius(new_radius)
    local var = "movement.black_hole_drive.alt_radius"
    ga_package_init_i(var, 3)
    return ga_package_set_i(var, new_radius)
end

--Returns true iff actually claimed the milestone.
function p.claim_milestone(level)
    if( level == 10 ) then
       for i = 1,20 do
           game_upgrades.health_regen()
       end
       return true
    end
    if( level == 20 ) then
        for i = 1,20 do
            game_upgrades.health_max()
        end
        return true
    end
    if( level == 30 ) then
        game_upgrades.laser_max_ammo()
        return true
    end
    if( level == 40 ) then
        for i = 1,20 do
            game_upgrades.cannon_damage();

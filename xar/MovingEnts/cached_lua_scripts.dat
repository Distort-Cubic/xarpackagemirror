function p.explode(inst_id, level, lp)
    ga_play_sound("rocket_explode")

    --Cannot get the sllp the usual way because
    --this could be during a ment move operation./
    --(PROBABLY SHOULD UPDATE MENT POS DURING THE MOVE?!?!?)

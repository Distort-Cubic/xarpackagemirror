        args.pos = sllp
        args.ttl = 1.0
        args.size = 0.2
        args.color = std.vec(1.0, 1.0, 1.0)
        args.fade_time = 0.5
        args.vel = std.vec_scale(dir, 0.5)
        args.tex = "particle_2"
        args.use_min_dist = false
        ga_particle_add(args)
    end

    return true
end
